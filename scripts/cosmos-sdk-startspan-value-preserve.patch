@@ -441,9 +441,35 @@ func (c Context) WithIncarnationCache(cache map[string]any) Context {
 
 // StartSpan starts an otel span and returns a new context with the span attached.
 // Use this instead of calling tracer.Start directly to have the span correctly
 // attached to this context type.
+//
+// The returned context preserves values from baseCtx (e.g. gas register, tx counter).
+// tracer.Start may return a context that does not properly chain to the parent
